<!DOCTYPE html>
<html lang="en">
  <%- include('components/head.html') %>
  <body>
    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js" integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <% switch (page) {
      case 'login': %>
        <%- include('pages/auth/index',{page,pageData}) %>
        <% break; %>  
      <% case 'signup': %>
        <%- include('pages/auth/index',{page,pageData}) %>
        <% break; %>  
      <% case 'verify': %>
        <%- include('pages/auth/index',{page,pageData}) %>
        <% break; %>
      <% case 'register': %>
        <%- include('pages/auth/index',{page,pageData}) %>
        <% break; %>
      <% case 'about': %>
        <%- include('pages/about.html',{page,pageData}) %>
        <% break; %>
      <% default: %>
        <%- include('pages/user-layout.html',{page,pageData}) %>
        <% break; %>
    <% } %>
    <script type="module" src="/js/glass/index.js" defer="async"></script>
  </body>
</html>