{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2017",
    "lib": [
      "es2017",
      "esnext.asynciterable",
    ],
    "typeRoots": ["node_modules/@types","types"],
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "module": "node16",
    "pretty": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "dist",
    "allowJs": true,
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "paths": {
      "@apps/*":["./src/apps/*"],
      "@middleware":["./src/middleware"],
      "@models":["./src/models"],
      "@services":["./src/services"],
      "@types":["./src/types"],
      "@utils":["./src/utils"],
      "@workers":["./src/workers"],
    }
  },
  "exclude": [
    "node_modules",
    "dist",
  ],
  "ts-node": {
    "files": true
  },
  "files": [
    "index.ts",
    "index-workers.ts",
    "types/global.d.ts",
    "types/cctx-common.d.ts",
    "types/cctx-entity.d.ts",
    "types/cctx-errors.d.ts",
    "types/cctx-utils.d.ts",
    "types/express-types.d.ts",
  ],
}