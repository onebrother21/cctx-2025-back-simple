{
  "name": "ccdev-2025-back-simple",
  "version": "1.3.14",
  "description": "backend services for ColorCoded dev apps",
  "main": "index.ts",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "dev": "npx nodemon -e ts,js,json --exec ts-node -r tsconfig-paths/register index.ts",
    "dev-workers": "npx nodemon -e ts,js,json --exec ts-node -r tsconfig-paths/register index-workers.ts",
    "dev-cli": "node ./bin/my-cli.js init",
    "lint": "eslint --ignore-path .gitignore --ext .ts src/",
    "lint:fix": "npm run lint -- --fix"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "typescript",
    "js",
    "ts"
  ],
  "author": "ColorCoded",
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "bluebird": "^3.7.2",
    "bullmq": "^5.73.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "csrf-csrf": "^4.0.3",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-list-routes": "^1.3.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "i18next": "^26.0.3",
    "i18next-fs-backend": "^2.6.3",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "mongoose-unique-validator": "^6.1.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1",
    "ua-parser-js": "^2.0.9"
  },
  "jest": {
    "setupFiles": [
      "./src/utils/loadenv.ts"
    ],
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/redis-info": "^3.0.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
